# ═══════════════════════════════════════════════════════════
# NeuroAntiSpam — Пример переменных окружения
# Скопируй этот файл в .env и заполни своими значениями
# ═══════════════════════════════════════════════════════════

# ── Telegram Bot (обязательно) ────────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_USERNAME=NeuroAntiSpamBot

# ── База данных ────────────────────────────────────────────
# Для разработки (SQLite):
DATABASE_URL=sqlite+aiosqlite:///neuroantispam.db
# Для продакшена (PostgreSQL, Railway даёт бесплатно):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Безопасность сайта (обязательно, сгенерируй случайные) ──
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=замени-на-случайную-строку-минимум-32-символа
API_SECRET_KEY=замени-на-другую-случайную-строку-32-символа

# ── Сайт ───────────────────────────────────────────────────
WEBSITE_URL=https://neuroantispam.up.railway.app

# ── ИИ (опционально, но рекомендуется — бесплатный тариф) ──
# Получить ключ: https://aistudio.google.com
GEMINI_API_KEY=

# ── GitHub (для автообновления базы спама) ──────────────────
GH_TOKEN=
GH_REPO=your-username/neuroantispam

# ── Супер-администраторы (через запятую, без пробелов) ──────
# Узнать свой ID: напиши @userinfobot в Telegram
SUPER_ADMINS=123456789,987654321
